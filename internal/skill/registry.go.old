package skill

import (
	"encoding/json"
	"fmt"
	"os"
	"path/filepath"
	"sync"
	"time"

	"github.com/fsnotify/fsnotify"
	"github.com/sirupsen/logrus"
)

// SkillType represents the type of skill
type SkillType string

const (
	BuiltinType SkillType = "builtin"
	OrgType     SkillType = "org"
	UserType    SkillType = "user"
)

// Skill represents a skill that can be executed
type Skill struct {
	ID          string                 `json:"id"`
	Name        string                 `json:"name"`
	Description string                 `json:"description"`
	Type        SkillType              `json:"type"`
	Version     string                 `json:"version"`
	Pages       []string               `json:"pages"`
	Schema      SkillSchema             `json:"schema"`
	Handler     Handler                `json:"handler"`
	Metadata    map[string]interface{} `json:"metadata,omitempty"`
	LastUpdated time.Time              `json:"last_updated"`
}

// SkillSchema defines the skill's input/output schema
type SkillSchema struct {
	Input  json.RawMessage `json:"input"`
	Output json.RawMessage `json:"output"`
}

// Handler represents the skill execution handler
type Handler struct {
	Func      func(args map[string]interface{}) (interface{}, error)
	Path      string `json:"path"` // For file-based skills
}

// SkillRegistry manages all skills
type SkillRegistry struct {
	skills      map[string]*Skill
	skillPaths  map[SkillType]string
	watcher     *fsnotify.Watcher
	mu          sync.RWMutex
	logger      *logrus.Logger
	reloadChan  chan struct{}
}

// NewSkillRegistry creates a new skill registry
func NewSkillRegistry() (*SkillRegistry, error) {
	watcher, err := fsnotify.NewWatcher()
	if err != nil {
		return nil, fmt.Errorf("failed to create watcher: %w", err)
	}

	return &SkillRegistry{
		skills:     make(map[string]*Skill),
		skillPaths:  make(map[SkillType]string),
		watcher:    watcher,
		logger:      logrus.New(),
		reloadChan:  make(chan struct{}, 1),
	}, nil
}

// Initialize sets up the skill registry with default paths
func (sr *SkillRegistry) Initialize() error {
	// Set default skill paths
	sr.skillPaths[BuiltinType] = "skills/builtin"
	sr.skillPaths[OrgType] = "skills/org"
	sr.skillPaths[UserType] = "skills/user"

	// Create directories if they don't exist
	for _, path := range sr.skillPaths {
		if err := createDirIfNotExists(path); err != nil {
			return fmt.Errorf("failed to create skill directory %s: %w", path, err)
		}
	}

	// Load initial skills
	if err := sr.LoadAllSkills(); err != nil {
		return fmt.Errorf("failed to load initial skills: %w", err)
	}

	// Start watching for skill changes
	go sr.watchSkillChanges()

	return nil
}

// LoadAllSkills loads all skills from the filesystem
func (sr *SkillRegistry) LoadAllSkills() error {
	sr.mu.Lock()
	defer sr.mu.Unlock()

	// Clear existing skills
	sr.skills = make(map[string]*Skill)

	// Load skills from each type
	for skillType, path := range sr.skillPaths {
		if err := sr.loadSkillsFromDirectory(skillType, path); err != nil {
			sr.logger.WithError(err).WithField("type", skillType).Error("Failed to load skills")
		}
	}

	sr.logger.Infof("Loaded %d skills", len(sr.skills))
	return nil
}

// loadSkillsFromDirectory loads skills from a directory
func (sr *SkillRegistry) loadSkillsFromDirectory(skillType SkillType, dirPath string) error {
	files, err := filepath.Glob(filepath.Join(dirPath, "*.json"))
	if err != nil {
		return fmt.Errorf("failed to glob skill files: %w", err)
	}

	for _, file := range files {
		skill, err := sr.loadSkillFromFile(skillType, file)
		if err != nil {
			sr.logger.WithError(err).WithField("file", file).Warn("Failed to load skill")
			continue
		}

		sr.skills[skill.ID] = skill
		sr.logger.WithField("skill", skill.Name).Info("Loaded skill")
	}

	return nil
}

// loadSkillFromFile loads a skill from a JSON file
func (sr *SkillRegistry) loadSkillFromFile(skillType SkillType, filePath string) (*Skill, error) {
	data, err := readJSONFile(filePath)
	if err != nil {
		return nil, fmt.Errorf("failed to read skill file: %w", err)
	}

	var skill Skill
	if err := json.Unmarshal(data, &skill); err != nil {
		return nil, fmt.Errorf("failed to unmarshal skill: %w", err)
	}

	// Set skill type and update time
	skill.Type = skillType
	skill.LastUpdated = time.Now()

	// Validate skill
	if err := validateSkill(&skill); err != nil {
		return nil, fmt.Errorf("invalid skill: %w", err)
	}

	return &skill, nil
}

// SelectSkills selects skills based on page context
func (sr *SkillRegistry) SelectSkills(pageContext string) ([]*Skill, error) {
	sr.mu.RLock()
	defer sr.mu.RUnlock()

	var selected []*Skill

	sr.logger.WithField("page_context", pageContext).Info("Selecting skills")

	for _, skill := range sr.skills {
		// Check if skill supports this page
		if len(skill.Pages) == 0 || contains(skill.Pages, pageContext) {
			sr.logger.WithFields(logrus.Fields{
				"skill": skill.Name,
				"pages": skill.Pages,
				"matched": true,
			}).Info("Skill selected")
			selected = append(selected, skill)
		} else {
			sr.logger.WithFields(logrus.Fields{
				"skill": skill.Name,
				"pages": skill.Pages,
				"matched": false,
			}).Debug("Skill not selected")
		}
	}

	sr.logger.WithField("count", len(selected)).Info("Total skills selected")
	return selected, nil
}

// GetSkill retrieves a skill by ID
func (sr *SkillRegistry) GetSkill(id string) (*Skill, error) {
	sr.mu.RLock()
	defer sr.mu.RUnlock()

	skill, exists := sr.skills[id]
	if !exists {
		return nil, fmt.Errorf("skill not found: %s", id)
	}

	return skill, nil
}

// RegisterSkill registers a new skill
func (sr *SkillRegistry) RegisterSkill(skill *Skill) error {
	sr.mu.Lock()
	defer sr.mu.Unlock()

	// Validate skill
	if err := validateSkill(skill); err != nil {
		return fmt.Errorf("invalid skill: %w", err)
	}

	skill.LastUpdated = time.Now()
	sr.skills[skill.ID] = skill

	// Signal reload
	select {
	case sr.reloadChan <- struct{}{}:
	default:
	}

	sr.logger.WithField("skill", skill.Name).Info("Registered skill")
	return nil
}

// ReloadSkills triggers a reload of all skills
func (sr *SkillRegistry) ReloadSkills() {
	select {
	case sr.reloadChan <- struct{}{}:
	default:
	}
}

// watchSkillChanges watches for skill file changes
func (sr *SkillRegistry) watchSkillChanges() {
	for _, path := range sr.skillPaths {
		if err := sr.watcher.Add(path); err != nil {
			sr.logger.WithError(err).WithField("path", path).Error("Failed to watch skill directory")
		}
	}

	for {
		select {
		case event, ok := <-sr.watcher.Events:
			if !ok {
				return
			}

			if event.Op&fsnotify.Write == fsnotify.Write ||
			   event.Op&fsnotify.Create == fsnotify.Create ||
			   event.Op&fsnotify.Remove == fsnotify.Remove {

				sr.logger.WithField("event", event).Info("Skill file changed, triggering reload")
				sr.LoadAllSkills()
			}

		case err, ok := <-sr.watcher.Errors:
			if !ok {
				return
			}
			sr.logger.WithError(err).Error("Watcher error")
		}
	}
}

// validateSkill validates a skill definition
func validateSkill(skill *Skill) error {
	if skill.ID == "" {
		return fmt.Errorf("skill ID is required")
	}

	if skill.Name == "" {
		return fmt.Errorf("skill name is required")
	}

	if skill.Type == "" {
		return fmt.Errorf("skill type is required")
	}

	if skill.Description == "" {
		return fmt.Errorf("skill description is required")
	}

	// Validate schema if provided
	if len(skill.Schema.Input) > 0 {
		var schema interface{}
		if err := json.Unmarshal(skill.Schema.Input, &schema); err != nil {
			return fmt.Errorf("invalid input schema: %w", err)
		}
	}

	if len(skill.Schema.Output) > 0 {
		var schema interface{}
		if err := json.Unmarshal(skill.Schema.Output, &schema); err != nil {
			return fmt.Errorf("invalid output schema: %w", err)
		}
	}

	return nil
}

// createDirIfNotExists creates a directory if it doesn't exist
func createDirIfNotExists(path string) error {
	if _, err := os.Stat(path); os.IsNotExist(err) {
		return os.MkdirAll(path, 0755)
	}
	return nil
}

// readJSONFile reads a JSON file
func readJSONFile(path string) ([]byte, error) {
	return os.ReadFile(path)
}

// contains checks if a string is in a slice
func contains(slice []string, item string) bool {
	for _, s := range slice {
		if s == item {
			return true
		}
	}
	return false
}
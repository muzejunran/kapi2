package skill

import (
	"context"
	"encoding/json"
	"fmt"
	"time"

	"ai-assistant-service/internal/model"
	"ai-assistant-service/internal/repository"
)

// SkillExecutor handles skill execution with timeout and error handling
type SkillExecutor struct {
	timeout  time.Duration
	billRepo *repository.BillRepository
}

// NewSkillExecutor creates a new skill executor
func NewSkillExecutor(timeout time.Duration, billRepo *repository.BillRepository) *SkillExecutor {
	return &SkillExecutor{
		timeout:  timeout,
		billRepo: billRepo,
	}
}

// Execute executes a skill with the given arguments
func (se *SkillExecutor) Execute(ctx context.Context, skill *Skill, args map[string]interface{}) (interface{}, error) {
	// Validate input arguments if schema is defined
	if len(skill.Schema.Input) > 0 {
		if err := se.validateInput(skill.Schema.Input, args); err != nil {
			return nil, fmt.Errorf("invalid input: %w", err)
		}
	}

	// Create a context with timeout
	ctx, cancel := context.WithTimeout(ctx, se.timeout)
	defer cancel()

	// Execute the skill
	result, err := se.executeWithTimeout(ctx, skill, args)
	if err != nil {
		return nil, err
	}

	// Validate output if schema is defined
	if len(skill.Schema.Output) > 0 {
		if err := se.validateOutput(skill.Schema.Output, result); err != nil {
			return nil, fmt.Errorf("invalid output: %w", err)
		}
	}

	return result, nil
}

// executeWithTimeout executes a skill with context timeout
func (se *SkillExecutor) executeWithTimeout(ctx context.Context, skill *Skill, args map[string]interface{}) (interface{}, error) {
	// If skill has a direct function handler
	if skill.Handler.Func != nil {
		done := make(chan interface{})
		errChan := make(chan error, 1)

		go func() {
			result, err := skill.Handler.Func(args)
			if err != nil {
				errChan <- err
				return
			}
			done <- result
		}()

		select {
		case result := <-done:
			return result, nil
		case err := <-errChan:
			return nil, err
		case <-ctx.Done():
			return nil, fmt.Errorf("skill execution timeout: %s", skill.Name)
		}
	}

	// Otherwise, handle file-based skills
	return se.executeFileSkill(skill, args)
}

// executeFileSkill executes a file-based skill
func (se *SkillExecutor) executeFileSkill(skill *Skill, args map[string]interface{}) (interface{}, error) {
	// In a real implementation, this would execute the skill file
	// For now, return mock result based on skill name

	switch skill.Name {
	case "add_bill":
		return se.executeAddBill(args)
	case "query_bills":
		return se.executeQueryBills(args)
	case "budget_advisor":
		return se.executeBudgetAdvisor(args)
	default:
		return fmt.Sprintf("Mock result for skill: %s", skill.Name), nil
	}
}

// validateInput validates input against schema
func (se *SkillExecutor) validateInput(schema json.RawMessage, args map[string]interface{}) error {
	// In a real implementation, this would validate the JSON schema
	// For now, just return nil
	return nil
}

// validateOutput validates output against schema
func (se *SkillExecutor) validateOutput(schema json.RawMessage, result interface{}) error {
	// In a real implementation, this would validate the JSON schema
	// For now, just return nil
	return nil
}

// executeAddBill executes the add_bill skill
func (se *SkillExecutor) executeAddBill(args map[string]interface{}) (interface{}, error) {
	if se.billRepo == nil {
		return map[string]interface{}{
			"error": "数据库未初始化",
		}, nil
	}

	amount := getFloat(args, "amount")
	if amount <= 0 {
		return map[string]interface{}{
			"error": "金额必须大于0",
		}, nil
	}

	category, _ := args["category"].(string)
	if category == "" {
		return map[string]interface{}{
			"error": "分类不能为空",
		}, nil
	}

	description, _ := args["description"].(string)
	userID, _ := args["user_id"].(string)
	if userID == "" {
		userID = "default_user"
	}

	bill := &model.Bill{
		UserID:      userID,
		Amount:      amount,
		Category:    category,
		Description: description,
	}

	err := se.billRepo.AddBill(bill)
	if err != nil {
		return map[string]interface{}{
			"error": fmt.Sprintf("添加账单失败: %v", err),
		}, nil
	}

	return map[string]interface{}{
		"success": true,
		"bill_id": bill.ID,
		"message": "账单已成功添加",
		"details": map[string]interface{}{
			"amount":      bill.Amount,
			"category":    bill.Category,
			"description": bill.Description,
			"timestamp":   bill.Timestamp,
		},
	}, nil
}

// executeQueryBills executes the query_bills skill
func (se *SkillExecutor) executeQueryBills(args map[string]interface{}) (interface{}, error) {
	if se.billRepo == nil {
		return map[string]interface{}{
			"error": "数据库未初始化",
		}, nil
	}

	userID, _ := args["user_id"].(string)
	if userID == "" {
		userID = "default_user"
	}

	filter := &model.BillFilter{
		UserID:    userID,
		Category:   getString(args, "category"),
		StartDate:  getString(args, "start_date"),
		EndDate:    getString(args, "end_date"),
	}

	bills, summary, err := se.billRepo.QueryBills(filter)
	if err != nil {
		return map[string]interface{}{
			"error": fmt.Sprintf("查询账单失败: %v", err),
		}, nil
	}

	// 转换为 map 格式以返回
	billsMap := make([]map[string]interface{}, len(bills))
	for i, bill := range bills {
		billsMap[i] = map[string]interface{}{
			"id":          bill.ID,
			"amount":      bill.Amount,
			"category":    bill.Category,
			"description": bill.Description,
			"timestamp":   bill.Timestamp,
		}
	}

	return map[string]interface{}{
		"total": len(bills),
		"bills": billsMap,
		"summary": map[string]interface{}{
			"total_amount": summary.TotalAmount,
			"by_category": summary.ByCategory,
		},
	}, nil
}

// getString safely gets a string value from map
func getString(args map[string]interface{}, key string) string {
	if val, ok := args[key]; ok {
		if str, ok := val.(string); ok {
			return str
		}
	}
	return ""
}

// executeBudgetAdvisor executes a budget_advisor skill
func (se *SkillExecutor) executeBudgetAdvisor(args map[string]interface{}) (interface{}, error) {
	// Mock implementation
	income := getFloat(args, "income")
	expenses := getFloat(args, "expenses")

	if income == 0 {
		return map[string]interface{}{
			"error": "income is required",
		}, nil
	}

	netIncome := income - expenses
	savingsRate := netIncome / income * 100

	var advice string
	if savingsRate >= 20 {
		advice = "太棒了！您的储蓄率很健康，可以考虑增加投资。"
	} else if savingsRate >= 10 {
		advice = "不错！储蓄率达标，但还有优化空间。"
	} else {
		advice = "建议减少不必要的支出，提高储蓄率。"
	}

	// Use savingsGoal if provided
	recommendations := []string{
		"考虑削减娱乐支出",
		"建立应急基金",
		"设定长期理财目标",
	}
	if savingsGoal := args["savings_goal"]; savingsGoal != nil {
		if savingsGoalFloat, ok := savingsGoal.(float64); ok {
			if netIncome < savingsGoalFloat {
				recommendations = append(recommendations, fmt.Sprintf("距离储蓄目标还有 %.2f 元", savingsGoalFloat-netIncome))
			} else {
				recommendations = append(recommendations, "您已达成储蓄目标，继续保持！")
			}
		}
	}

	return map[string]interface{}{
		"current_savings_rate": savingsRate,
		"monthly_savings":     netIncome,
		"advice":             advice,
		"recommendations":      []string{
				"考虑削减娱乐支出",
				"建立应急基金",
				"设定长期理财目标",
			},
	}, nil
}

// getFloat safely gets a float value from map
func getFloat(args map[string]interface{}, key string) float64 {
	if val, ok := args[key]; ok {
		switch v := val.(type) {
		case float64:
			return v
		case float32:
			return float64(v)
		case int:
			return float64(v)
		case string:
			var f float64
			fmt.Sscanf(v, "%f", &f)
			return f
		}
	}
	return 0
}

package skill

import (
	"context"
	"encoding/json"
	"fmt"
	"regexp"

	"ai-assistant-service/internal/model"
	"ai-assistant-service/internal/repository"
)

// FinancialManagementSkill manages all financial operations
type FinancialManagementSkill struct {
	*BaseSkill
	billRepo *repository.BillRepository
}

// NewFinancialManagementSkill creates a new financial management skill
func NewFinancialManagementSkill(billRepo *repository.BillRepository) *FinancialManagementSkill {
	base := NewBaseSkill("financial_management", "财务管理", "管理用户的账单、预算和财务建议")

	// Register tools
	base.RegisterTool(Tool{
		ID:          "add_bill",
		Name:        "add_bill",
		Description: "添加一笔账单记录",
		Parameters:  json.RawMessage(`{"type":"object","properties":{"amount":{"type":"number","description":"金额"},"category":{"type":"string","description":"分类（如：餐饮、购物、交通等）"},"description":{"type":"string","description":"描述"},"timestamp":{"type":"string","description":"时间戳"}},"required":["amount","category"]}`),
		Handler:     nil, // Will be set in Initialize
	})

	base.RegisterTool(Tool{
		ID:          "query_bills",
		Name:        "query_bills",
		Description: "查询账单记录，支持按时间范围和分类筛选",
		Parameters:  json.RawMessage(`{"type":"object","properties":{"category":{"type":"string","description":"分类筛选"},"end_date":{"type":"string","description":"结束日期"},"start_date":{"type":"string","description":"开始日期"},"user_id":{"type":"string","description":"用户ID"}},"required":[]}`),
		Handler:     nil, // Will be set in Initialize
	})

	base.RegisterTool(Tool{
		ID:          "budget_advisor",
		Name:        "budget_advisor",
		Description: "根据收支情况提供预算建议",
		Parameters:  json.RawMessage(`{"type":"object","properties":{"expenses":{"type":"number","description":"支出金额"},"income":{"type":"number","description":"收入金额"},"savings_goal":{"type":"number","description":"储蓄目标"}},"required":["income","expenses"]}`),
		Handler:     nil, // Will be set in Initialize
	})

	return &FinancialManagementSkill{
		BaseSkill: base,
		billRepo:  billRepo,
	}
}

// Initialize sets up the skill
func (s *FinancialManagementSkill) Initialize(config map[string]interface{}) error {
	// Set up tool handlers
	for id, tool := range s.Tools {
		switch id {
		case "add_bill":
			tool.Handler = s.executeAddBill
		case "query_bills":
			tool.Handler = s.executeQueryBills
		case "budget_advisor":
			tool.Handler = s.executeBudgetAdvisor
		}
		s.Tools[id] = tool
	}
	return nil
}

// CanHandle evaluates if this skill can handle the current context
func (s *FinancialManagementSkill) CanHandle(ctx AgentContext) float64 {
	// Keywords that indicate financial management
	keywords := []string{
		"账单", "消费", "支出", "记账", "预算",
		"收入", "花费", "余额", "理财", "存钱",
		"bill", "expense", "budget", "money", "spend",
	}

	message := ctx.Message
	for _, keyword := range keywords {
		if regexp.MustCompile(`(?i)`+keyword).MatchString(message) {
			return 1.0
		}
	}

	// Also check if user is on financial pages
	if ctx.PageContext == "bills" || ctx.PageContext == "budget" {
		return 1.0
	}

	return 0
}

// Execute handles skill requests
func (s *FinancialManagementSkill) Execute(ctx context.Context, request SkillRequest) (*SkillResponse, error) {
	// Financial skill uses tools directly
	// The actual tool execution is handled by ToolExecutor
	return nil, fmt.Errorf("use ToolExecutor to execute individual tools")
}

// executeAddBill executes the add_bill tool
func (s *FinancialManagementSkill) executeAddBill(args map[string]interface{}) (interface{}, error) {
	if s.billRepo == nil {
		return map[string]interface{}{
			"error": "数据库未初始化",
		}, nil
	}

	amount := getFloat(args, "amount")
	if amount <= 0 {
		return map[string]interface{}{
			"error": "金额必须大于0",
		}, nil
	}

	category, _ := args["category"].(string)
	if category == "" {
		return map[string]interface{}{
			"error": "分类不能为空",
		}, nil
	}

	description, _ := args["description"].(string)
	userID, _ := args["user_id"].(string)
	if userID == "" {
		userID = "default_user"
	}

	bill := &model.Bill{
		UserID:      userID,
		Amount:      amount,
		Category:    category,
		Description: description,
	}

	err := s.billRepo.AddBill(bill)
	if err != nil {
		return map[string]interface{}{
			"error": fmt.Sprintf("添加账单失败: %v", err),
		}, nil
	}

	return map[string]interface{}{
		"success": true,
		"bill_id": bill.ID,
		"message": "账单已成功添加",
		"details": map[string]interface{}{
			"amount":      bill.Amount,
			"category":    bill.Category,
			"description": bill.Description,
			"timestamp":   bill.Timestamp,
		},
	}, nil
}

// executeQueryBills executes the query_bills tool
func (s *FinancialManagementSkill) executeQueryBills(args map[string]interface{}) (interface{}, error) {
	if s.billRepo == nil {
		return map[string]interface{}{
			"error": "数据库未初始化",
		}, nil
	}

	userID, _ := args["user_id"].(string)
	if userID == "" {
		userID = "default_user"
	}

	filter := &model.BillFilter{
		UserID:    userID,
		Category:   getString(args, "category"),
		StartDate:  getString(args, "start_date"),
		EndDate:    getString(args, "end_date"),
	}

	bills, summary, err := s.billRepo.QueryBills(filter)
	if err != nil {
		return map[string]interface{}{
			"error": fmt.Sprintf("查询账单失败: %v", err),
		}, nil
	}

	billsMap := make([]map[string]interface{}, len(bills))
	for i, bill := range bills {
		billsMap[i] = map[string]interface{}{
			"id":          bill.ID,
			"amount":      bill.Amount,
			"category":    bill.Category,
			"description": bill.Description,
			"timestamp":   bill.Timestamp,
		}
	}

	return map[string]interface{}{
		"total": len(bills),
		"bills": billsMap,
		"summary": map[string]interface{}{
			"total_amount": summary.TotalAmount,
			"by_category": summary.ByCategory,
		},
	}, nil
}

// executeBudgetAdvisor executes the budget_advisor tool
func (s *FinancialManagementSkill) executeBudgetAdvisor(args map[string]interface{}) (interface{}, error) {
	income := getFloat(args, "income")
	expenses := getFloat(args, "expenses")

	if income == 0 {
		return map[string]interface{}{
			"error": "income is required",
		}, nil
	}

	netIncome := income - expenses
	savingsRate := netIncome / income * 100

	var advice string
	if savingsRate >= 20 {
		advice = "太棒了！您的储蓄率很健康，可以考虑增加投资。"
	} else if savingsRate >= 10 {
		advice = "不错！储蓄率达标，但还有优化空间。"
	} else {
		advice = "建议减少不必要的支出，提高储蓄率。"
	}

	recommendations := []string{
		"考虑削减娱乐支出",
		"建立应急基金",
		"设定长期理财目标",
	}
	if savingsGoal := args["savings_goal"]; savingsGoal != nil {
		if savingsGoalFloat, ok := savingsGoal.(float64); ok {
			if netIncome < savingsGoalFloat {
				recommendations = append(recommendations, fmt.Sprintf("距离储蓄目标还有 %.2f 元", savingsGoalFloat-netIncome))
			} else {
				recommendations = append(recommendations, "您已达成储蓄目标，继续保持！")
			}
		}
	}

	return map[string]interface{}{
		"current_savings_rate": savingsRate,
		"monthly_savings":     netIncome,
		"advice":             advice,
		"recommendations":      recommendations,
	}, nil
}

// Helper functions for type conversions
func getFloat(args map[string]interface{}, key string) float64 {
	if val, ok := args[key]; ok {
		switch v := val.(type) {
		case float64:
			return v
		case float32:
			return float64(v)
		case int:
			return float64(v)
		case string:
			var f float64
			fmt.Sscanf(v, "%f", &f)
			return f
		}
	}
	return 0
}

func getString(args map[string]interface{}, key string) string {
	if val, ok := args[key]; ok {
		if str, ok := val.(string); ok {
			return str
		}
	}
	return ""
}

{
  "id": "add_bill",
  "name": "记账",
  "description": "记录一笔新的支出或收入",
  "version": "1.0.0",
  "enabled": true,
  "supported_pages": ["add_bill"],

  "tools": [
    {
      "type": "function",
      "function": {
        "name": "add_bill",
        "description": "记录一笔新的支出或收入",
        "parameters": {
          "type": "object",
          "properties": {
            "amount": {
              "type": "number",
              "minimum": 0,
              "description": "金额"
            },
            "category": {
              "type": "string",
              "enum": ["餐饮", "购物", "交通", "娱乐", "医疗", "其他"],
              "description": "消费分类"
            },
            "description": {
              "type": "string",
              "maxLength": 200,
              "description": "消费描述（可选）"
            }
          },
          "required": ["amount", "category"],
          "additionalProperties": false
        }
      }
    }
  ],

  "runtime_config": {
    "default_timeout_ms": 5000,
    "max_retries": 2,
    "error_message": "记账失败，请检查输入信息后重试"
  },

  "metadata": {
    "author": "system",
    "created_at": "2024-01-01T00:00:00Z",
    "updated_at": "2024-04-21T00:00:00Z",
    "tags": ["finance", "bill", "record"],
    "priority": 10
  }
}

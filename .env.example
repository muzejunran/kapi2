# ============================================
# KAPI Server Configuration
# ============================================

# Server
SERVER_PORT=8080
MONITORING_PORT=9090
JWT_SECRET=qwert

# ============================================
# Redis Configuration
# ============================================
REDIS_ADDR=redis:6379

# ============================================
# MySQL Configuration
# ============================================
MYSQL_ROOT_PASSWORD=11111111
MYSQL_DATABASE=kapi
MYSQL_USER=kapi
MYSQL_PASSWORD=kapi123
MYSQL_DSN=kapi:kapi123@tcp(mysql:3306)/kapi?charset=utf8mb4&parseTime=true

# ============================================
# LLM Configuration
# LLM 为外部服务，请配置你的 LLM provider
# ============================================
# 示例：智谱 AI
LLM_ENDPOINT=https://open.bigmodel.cn/api/paas/v4/chat/completions
LLM_API_KEY=your-api-key-here
MODEL_NAME=glm-4.6v

# 示例：OpenAI
# LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=sk-xxxxx
# MODEL_NAME=gpt-3.5-turbo

# ============================================
# Runtime Configuration
# ============================================
MAX_TOKENS=10000
TEMPERATURE=0.7
TOKEN_BUDGET=1500
SKILL_TIMEOUT=60s
RATE_LIMIT=100
